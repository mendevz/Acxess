{
  "DetailedErrors": true,
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.Seq"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://seq:5341"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName"
    ],
    "Properties": {
      "Application": "Acxess.Web",
      "Environment": "Development"
    }
  },
  "OpenTelemetry": {
    "Endpoint": "",
    "Token": ""
  },
  "ConnectionStrings": {
    "Default": "Data Source=;Database=AcxessDB;User ID=;Password=;Trust Server Certificate=True;",
    "Redis": ":,password=,abortConnect=False"
  },
  "CloudflareR2": {
    "BucketName": "",
    "AccessKey": "",
    "SecretKey": "",
    "ServiceURL": "",
    "PublicDomain": ""
  }
}