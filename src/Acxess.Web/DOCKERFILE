# RUN dotnet publish "Acxess.Web.csproj" -c Release -o /app/publish /p:UseAppHost=false

# # ETAPA 2: Runtime (Imagen ligera solo para ejecutar)
# FROM mcr.microsoft.com/dotnet/aspnet:9.0 AS final
# WORKDIR /app
# EXPOSE 8080
# EXPOSE 8081

# COPY --from=build /app/publish .
# ENTRYPOINT ["dotnet", "Acxess.Web.dll"]

# Build (SDK)
FROM mcr.microsoft.com/dotnet/sdk:9.0 AS build
WORKDIR /src

# Instalar Node.js 
RUN apt-get update && \
    apt-get install -y nodejs npm

# 1. Copiar Archivos de Configuración Global
COPY ["Directory.Packages.props*", "./"]
COPY ["Directory.Build.props*", "./"] 
COPY ["src/Directory.Packages.props*", "src/"]
COPY ["src/Directory.Build.props*", "src/"]

# 2. Copiar los CSPROJ de proyectos dependientes
COPY ["src/shared/Acxess.Shared/Acxess.Shared.csproj", "src/shared/Acxess.Shared/"]
COPY ["src/shared/Acxess.Infrastructure/Acxess.Infrastructure.csproj", "src/shared/Acxess.Infrastructure/"]
COPY ["src/modules/Acxess.Identity/Acxess.Identity.csproj", "src/modules/Acxess.Identity/"]
COPY ["src/modules/Acxess.Catalog/Acxess.Catalog.csproj", "src/modules/Acxess.Catalog/"]
COPY ["src/modules/Acxess.Membership/Acxess.Membership.csproj", "src/modules/Acxess.Membership/"]
COPY ["src/modules/Acxess.Billing/Acxess.Billing.csproj", "src/modules/Acxess.Billing/"]
COPY ["src/modules/Acxess.Marketing/Acxess.Marketing.csproj", "src/modules/Acxess.Marketing/"]

# 3. Copiar App Web
COPY ["src/Acxess.Web/Acxess.Web.csproj", "src/Acxess.Web/"]

# 4. Restaurar dependencias
RUN dotnet restore "src/Acxess.Web/Acxess.Web.csproj"

# 5. Copiar TODO el código fuente
COPY . .

# 6. Publish
ARG APP_VERSION=1.0.0-dev

WORKDIR /src/src/Acxess.Web
RUN npm install
RUN dotnet publish "Acxess.Web.csproj" -c Release -o /app/publish /p:UseAppHost=false /p:InformationalVersion=$APP_VERSION

# Runtime
FROM mcr.microsoft.com/dotnet/aspnet:9.0 AS final
WORKDIR /app
EXPOSE 8080
EXPOSE 8081

# Copiar compilado
COPY --from=build /app/publish .

# Comando de inicio
ENTRYPOINT ["dotnet", "Acxess.Web.dll"]
