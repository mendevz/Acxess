@using Acxess.Catalog.Application.Features.AccessTiers.Queries.GetAccessTiers
@model SellingPlanInputModel
@{
    var tiersList = ViewData["AvailableTiers"] as List<AccessTierDto> ?? [];
    var modelJson = System.Text.Json.JsonSerializer.Serialize(Model);
    var tiersJson = System.Text.Json.JsonSerializer.Serialize(tiersList);
}
<div class="h-full flex flex-col  overflow-hidden bg-gray-50 dark:bg-[#0f1523]"
     x-data="sellingPlanForm(@modelJson, @tiersJson)">
    
    <div class="flex-1 p-8 grid grid-cols-1  lg:grid-cols-2 overflow-y-auto gap-12 custom-scrollbar content-start min-h-0">
        <div class="space-y-6">
            <div class="mb-3 flex flex-col gap-2">
                <h2 class="text-lg font-bold text-gray-800 dark:text-white flex items-center gap-2">
                    <span>@(Model.IdSellingPlan == 0 ? "Crear Nuevo Plan" : "Editar Plan")</span>
                    <span x-show="isDirty" 
                          class="text-xs font-normal text-amber-600 bg-amber-100 dark:text-amber-300 dark:bg-amber-900/50 px-2 py-0.5 rounded animate-pulse">
                        ● Cambios sin guardar
                    </span>
                </h2>
                <p class="text-sm text-gray-500 dark:text-gray-400">Define las reglas de negocio para esta configuración.</p>
                
                <partial name="_FormFeedback" />
            </div>

            <form
                id="sellingPlanForm"
                method="post"
                hx-post="@Url.Page("Index", "Save")"
                hx-target="#form-container"
                class="flex flex-col gap-3">
                
                <input type="hidden" asp-for="IdSellingPlan"/>

                <div>
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Nombre Comercial</label>
                    <input type="text"
                           asp-for="Name"
                           name="Input.Name"
                           x-model="form.Name"
                           placeholder="Ej. Mensualidad Estudiante"
                           class="form-input-acxess"
                           id="Input_Name"><span asp-validation-for="Name" class="text-xs text-red-500 font-bold mt-1 block"></span>
                </div>

                <div >
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Cantidad de Miembros</label>
                    <input type="number"
                           asp-for="TotalMembers"
                           name="Input.TotalMembers"
                           x-model="form.TotalMembers"
                           class="form-input-acxess"
                           placeholder="Ej. 3"
                           id="Input_TotalMembers"> <span asp-validation-for="TotalMembers" class="text-xs text-red-500 font-bold mt-1 block"></span>
                </div>

                <div class="grid grid-cols-2 gap-4 ">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Precio</label>
                        <div class="relative group">
                            <span class="absolute left-3 top-2.5 text-gray-400 group-focus-within:text-blue-500 transition-colors">$</span>
                            <input type="number"
                                   name="Input.Price"
                                   id="Input_Price"
                                   asp-for="Price"
                                   x-model="form.Price"
                                   class="form-input-acxess !pl-9 font-mono font-bold w-full">

                            <span asp-validation-for="Price" class="text-xs text-red-500 font-bold mt-1 block"></span>
                        </div>
                    </div>

                    <div class="flex flex-col justify-end pb-2">
                        <label class="flex items-center cursor-pointer group">
                            <div class="relative">
                                <input 
                                    type="checkbox" 
                                    asp-for="IsActive" 
                                    x-model="form.IsActive" 
                                    class="sr-only">
                                <div :class="form.IsActive ? 'bg-green-500' : 'bg-gray-300 dark:bg-slate-600'" class="w-10 h-6 rounded-full shadow-inner transition-colors"></div>
                                <div :class="form.IsActive ? 'translate-x-4' : 'translate-x-0'" class="absolute left-1 top-1 bg-white w-4 h-4 rounded-full shadow transition-transform transform"></div>
                            </div>
                            <span class="ml-3 text-sm font-medium text-gray-700 dark:text-gray-300 group-hover:text-blue-500 transition-colors" x-text="form.IsActive ? 'Disponible' : 'Archivado'"></span>
                        </label>
                    </div>
                </div>

                <div class=" bg-white dark:bg-slate-800 p-4 rounded-lg border border-gray-200 dark:border-slate-700 shadow-sm">
                    <label class="block text-xs font-bold text-gray-400 dark:text-gray-500 uppercase mb-3 tracking-wide">Vigencia del servicio</label>
                    <div class="flex gap-4">
                        <div class="w-1/3">
                            <label class="text-xs text-gray-500 dark:text-gray-400 block mb-1">Valor</label>
                            <input
                                type="number"
                                name="Input.DurationInValue"
                                asp-for="DurationInValue"
                                id="Input_DurationInValue"
                                x-model="form.DurationInValue"
                                class="form-input-acxess">
                            <span asp-validation-for="DurationInValue" class="text-xs text-red-500 font-bold mt-1 block"></span>
                        </div>
                        <div class="flex-1">
                            <label class="text-xs text-gray-500 dark:text-gray-400 block mb-1">Unidad</label>
                            <select
                                name="Input.DurationUnit"
                                id="Input_durationUnit"
                                asp-for="DurationUnit"
                                x-model.number="form.DurationUnit"
                                class="w-full p-2 border border-gray-300 dark:border-slate-600 bg-white dark:bg-slate-900 text-gray-900 dark:text-white rounded focus:ring-blue-500 outline-none transition-colors">
                                <option value="1">Días</option>
                                <option value="2">Meses</option>
                                <option value="3">Años</option>
                            </select>
                        </div>
                    </div>
                    <p class="mt-3 text-xs text-blue-600 dark:text-blue-400 bg-blue-50 dark:bg-blue-900/20 p-2 rounded border border-blue-100 dark:border-blue-900/30">
                        <span class="font-bold">Info:</span> El sistema sumará
                        <span x-text="form.DurationInValue"></span>
                        <span x-text="durationLabel"></span>
                        a la fecha de compra.
                    </p>
                </div>

                <div class="flex flex-col justify-between items-start mb-1">
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Niveles de acceso</label>
                    <span asp-validation-for="AccessTiersIds" class="text-xs text-red-500 dark:text-red-400 font-bold block"></span>
                </div>

                <div class="grid grid-cols-2 gap-2">
                    @foreach (var tier in tiersList)
                    {
                        var isSelected = Model.AccessTiersIds.Contains(tier.IdAccessTier);

                        <label x-data="{ checked: @isSelected.ToString().ToLower() }"
                               class="cursor-pointer border p-2 rounded text-xs flex items-center gap-2 transition-colors duration-200 select-none"
                               :class="form.AccessTiersIds.includes(@tier.IdAccessTier)
                                    ? 'bg-blue-50 border-blue-500 text-blue-700 dark:bg-blue-900/30 dark:border-blue-500 dark:text-blue-300' 
                                    : 'bg-white border-gray-200 text-gray-600 dark:bg-slate-900 dark:border-slate-700 dark:text-gray-300 hover:border-gray-300 dark:hover:border-slate-500'">

                            <input type="checkbox"
                                   name="Input.AccessTiersIds"
                                   value="@tier.IdAccessTier"
                                   class="hidden"
                                   x-model.number="form.AccessTiersIds"/>

                            <div class="w-4 h-4 border rounded flex items-center justify-center transition-colors"
                                 :class="form.AccessTiersIds.includes(@tier.IdAccessTier)
                                    ? 'bg-blue-500 border-blue-500 dark:bg-blue-600 dark:border-blue-600' 
                                    : 'border-gray-300 dark:border-slate-500'">

                                <svg x-show="form.AccessTiersIds.includes(@tier.IdAccessTier)"
                                     x-transition.opacity
                                     class="w-3 h-3 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                                </svg>
                            </div>

                            <span>@tier.Name</span>
                        </label>
                    }
                </div>
            </form>
        </div>
        <partial name="_PreviewPlan"/>
    </div>

    <div class="bg-white dark:bg-slate-800 border-t border-gray-200 dark:border-slate-700 p-4 flex justify-between items-center shrink-0 z-20 shadow-[0_-4px_6px_-1px_rgba(0,0,0,0.1)]">
        <button
            type="button"
            @@click="selectedId = null"
            hx-get="@Url.Page("Index", "Form")"
            hx-target="#form-container"
            class="px-4 py-2 text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-slate-700 rounded-lg text-sm transition-colors">
            Cancelar <span class="bg-gray-200 dark:bg-slate-600 text-gray-500 dark:text-gray-300 px-1 py-0.5 rounded text-[10px] ml-1 border border-gray-300 dark:border-slate-500">Esc</span>
        </button>
        <button
            id="btnSave"
            class="px-6 py-2 bg-slate-900 hover:bg-black dark:bg-blue-600 dark:hover:bg-blue-500 text-white rounded-lg shadow-lg text-sm font-bold flex items-center gap-2 transform active:scale-95 transition-all disabled:opacity-70 disabled:cursor-not-allowed"
            type="submit"
            form="sellingPlanForm"
            :disabled=" !isDirty">
            <span x-show="!isLoading">GUARDAR CAMBIOS</span>

            <span x-show="isLoading" class="flex items-center gap-2">
                GUARDANDO...
                <svg class="animate-spin h-4 w-4 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                </svg>
            </span>
        </button>
    </div>
</div>

