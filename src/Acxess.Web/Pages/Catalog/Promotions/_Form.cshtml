@model Acxess.Web.Pages.Catalog.Promotions.PromotionInputModel
@{
    var modelJson = System.Text.Json.JsonSerializer.Serialize(Model);
}

<div class="h-full flex flex-col  overflow-hidden bg-gray-50 dark:bg-[#0f1523]"
     x-data="promotionsForm(@modelJson)">
    
    
    <div class="flex-1 p-8 grid grid-cols-1  overflow-y-auto gap-12 custom-scrollbar content-start min-h-0">
        <div class="space-y-6">
            <div class="mb-3 flex flex-col gap-2">
                <h2 class="text-lg font-bold text-gray-800 dark:text-white flex items-center gap-2">
                    <span>@(Model.IdPromotion == 0 ? "Nueva Promoción" : "Editar Promoción")</span>
                    <span x-show="isDirty" 
                          class="text-xs font-normal text-amber-600 bg-amber-100 dark:text-amber-300 dark:bg-amber-900/50 px-2 py-0.5 rounded animate-pulse"
                          x-transition>
                        ● Cambios sin guardar
                    </span>
                </h2>
                <p class="text-sm text-gray-500 dark:text-gray-400">Configura las reglas de descuento y vigencia.</p>
                <partial name="_FormFeedback"/> 
            </div>
            
            
            <form id="promotionForm"
                  method="post"
                  hx-post="@Url.Page("Index", "Save")"
                  hx-target="#form-container"
                  class="flex flex-col gap-3 max-w-2xl">
                
                <input type="hidden" asp-for="IdPromotion"/>
                
                <div>
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Nombre de la Promoción</label>
                    <input type="text" asp-for="Name" 
                           x-model="form.Name"
                           class="form-input-acxess" 
                           placeholder="Ej. Verano 2026">
                    <span asp-validation-for="Name" class="text-xs text-red-500 font-bold mt-1 block"></span>
                </div>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Tipo de Descuento</label>
                        <div class="flex bg-gray-200 dark:bg-slate-700 p-1 rounded-lg">
                            <button type="button" 
                                    @@click="form.DiscountType = 1"
                                    :class="form.DiscountType === 1 ? 'bg-white dark:bg-slate-600 text-blue-600 dark:text-blue-400 shadow-sm' : 'text-gray-500 dark:text-gray-400 hover:text-gray-700'"
                                    class="flex-1 py-1.5 text-sm font-medium rounded-md transition-all">
                                Porcentaje (%)
                            </button>
                            <button type="button" 
                                    @@click="form.DiscountType = 2"
                                    :class="form.DiscountType === 2 ? 'bg-white dark:bg-slate-600 text-green-600 dark:text-green-400 shadow-sm' : 'text-gray-500 dark:text-gray-400 hover:text-gray-700'"
                                    class="flex-1 py-1.5 text-sm font-medium rounded-md transition-all">
                                Monto Fijo ($)
                            </button>
                        </div>
                        <input type="hidden" asp-for="DiscountType" x-model="form.DiscountType" />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Valor del Descuento</label>
                        <div class="relative">
                            <input type="number" asp-for="Discount" x-model="form.Discount"
                                   class="form-input-acxess !pl-9 font-mono font-bold" placeholder="0.00">
                            <span class="absolute left-3 top-2.5 text-gray-400 group-focus-within:text-blue-500 transition-colors" x-text="discountSymbol"></span>
                        </div>
                        <span asp-validation-for="Discount" class="text-xs text-red-500 font-bold mt-1 block"></span>
                    </div>
                </div>
                
                <hr class="border-gray-200 dark:border-slate-700 my-2" />
                
                <div class="flex items-center justify-between bg-white dark:bg-slate-800 p-4 rounded-lg border border-gray-200 dark:border-slate-700">
                    <div>
                        <span class="block text-sm font-medium text-gray-900 dark:text-white">Aplica a cupones</span>
                        <span class="block text-xs text-gray-500">Si se activa, esta promoción no tiene fecha límite general, depende del cupón.</span>
                    </div>
                    <label class="flex items-center cursor-pointer relative">
                        <input type="checkbox" asp-for="RequiresCoupon" x-model="form.RequiresCoupon" class="sr-only">
                        <div :class="form.RequiresCoupon ? 'bg-blue-500' : 'bg-gray-300 dark:bg-slate-600'" 
                             class="w-11 h-6 rounded-full shadow-inner transition-colors duration-200 ease-in-out"></div>
                        <div :class="form.RequiresCoupon ? 'translate-x-5' : 'translate-x-0'" 
                             class="absolute left-1 top-1 bg-white w-4 h-4 rounded-full shadow transform transition-transform duration-200 ease-in-out"></div>
                    </label>
                </div>
                
                <div x-show="!form.RequiresCoupon"
                     x-transition:enter="transition ease-out duration-200"
                     x-transition:enter-start="opacity-0 -translate-y-2"
                     x-transition:enter-end="opacity-100 translate-y-0"
                     x-transition:leave="transition ease-in duration-150"
                     x-transition:leave-start="opacity-100 translate-y-0"
                     x-transition:leave-end="opacity-0 -translate-y-2"
                     class="space-y-5 border-l-2 border-gray-200 dark:border-slate-700 pl-4 ml-2">
                    
                    <div class="flex items-start">
                        <div class="flex items-center h-5">
                            <input asp-for="AutoApply" x-model="form.AutoApply" type="checkbox"
                                   class="focus:ring-blue-500 h-4 w-4 text-blue-600 border-gray-300 rounded">
                        </div>
                        <div class="ml-3 text-sm">
                            <label asp-for="AutoApply" class="font-medium text-gray-700 dark:text-gray-300">Aplicar automáticamente</label>
                            <p class="text-gray-500 dark:text-gray-400 text-xs">El sistema aplicará el descuento sin preguntar al usuario.</p>
                        </div>
                    </div>
                    
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Válido Desde</label>
                            <input asp-for="AvailableFrom" 
                                   asp-format="{0:yyyy-MM-dd}"
                                   x-model="form.AvailableFrom"
                                   type="date" 
                                   class="form-input-acxess dark:[color-scheme:dark]" />
                        </div>
    
                        <div>
                            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Válido Hasta</label>
                            <input asp-for="AvailableTo" 
                                   asp-format="{0:yyyy-MM-dd}"
                                   x-model="form.AvailableTo"
                                   type="date" 
                                   class="form-input-acxess dark:[color-scheme:dark]" />
                        </div>
                    </div>
                </div>
                
                <div class="flex pt-4">
                    <label class="flex items-center cursor-pointer group">
                        <span class="mr-3 text-sm font-medium text-gray-700 dark:text-gray-300" x-text="form.IsActive ? 'Promoción Activa' : 'Archivada'"></span>
                        <div class="relative">
                            <input type="checkbox" asp-for="IsActive" class="sr-only" x-model="form.IsActive">
                            <div :class="form.IsActive ? 'bg-green-500' : 'bg-gray-300 dark:bg-slate-600'" class="w-10 h-6 rounded-full shadow-inner transition-colors"></div>
                            <div :class="form.IsActive ? 'translate-x-4' : 'translate-x-0'" class="absolute left-1 top-1 bg-white w-4 h-4 rounded-full shadow transition-transform transform"></div>
                        </div>
                    </label>
                </div>
                
            </form>
            
            
            
        </div>

    </div>
    <div class="bg-white dark:bg-slate-800 border-t border-gray-200 dark:border-slate-700 p-4 flex justify-between items-center shrink-0 z-20 shadow-[0_-4px_6px_-1px_rgba(0,0,0,0.1)]">
        <button type="button"
                @@click="selectedId = null"
                hx-get="@Url.Page("Index", "Form")"
                hx-target="#form-container"
                class="px-4 py-2 text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-slate-700 rounded-lg text-sm transition-colors">
            Cancelar <span class="bg-gray-200 dark:bg-slate-600 text-gray-500 dark:text-gray-300 px-1 py-0.5 rounded text-[10px] ml-1 border border-gray-300 dark:border-slate-500">Esc</span>
        </button>

        <button id="btnSave"
                class="px-6 py-2 bg-slate-900 hover:bg-black dark:bg-blue-600 dark:hover:bg-blue-500 text-white rounded-lg shadow-lg text-sm font-bold flex items-center gap-2 transform active:scale-95 transition-all disabled:opacity-70 disabled:cursor-not-allowed"
                type="submit"
                form="promotionForm"
                :disabled="!isDirty">
            
            <span x-show="!isLoading">GUARDAR CAMBIOS</span>
            <span x-show="isLoading" class="flex items-center gap-2">
                GUARDANDO...
                <svg class="animate-spin h-4 w-4 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                </svg>
            </span>
        </button>
    </div>
    
    
</div>