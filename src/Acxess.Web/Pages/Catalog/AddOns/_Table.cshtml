@model Acxess.Web.Pages.Catalog.AddOns.IndexModel


<div class="h-full flex flex-col bg-white dark:bg-slate-800"
    x-data="{ show: false }"
     x-init="$nextTick(() => show = true)"
     x-show="show"
     x-transition:enter="transition ease-out duration-300"
     x-transition:enter-start="opacity-0"
     x-transition:enter-end="opacity-100">


    <div class="p-4 border-b border-gray-100 dark:border-slate-700 bg-gray-50 dark:bg-slate-800/50 flex justify-between items-center gap-2">
        <div class="relative w-full">
            <input type="text" 
                name="Search"
                value="@Model.Search"
                placeholder="Filtrar..." 
                class="w-full pl-8 pr-2 py-1.5 text-sm bg-white dark:bg-slate-900 border border-gray-300 dark:border-slate-600 rounded-md focus:ring-1 focus:ring-blue-500 outline-none transition-colors"
                hx-get="@Url.Page("Index", "Items")"
                hx-target="#table-content"
                hx-trigger="keyup changed delay:500ms">
            <svg class="w-4 h-4 text-gray-400 absolute left-2.5 top-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
        </div>
        
        <button 
            @@click="selectedId = 0"
            hx-get="@Url.Page("Index", "Form", new { id = 0 })"
            hx-target="#form-container"
            class="flex items-center gap-1 bg-blue-600 hover:bg-blue-700 text-white px-3 py-1.5 rounded-md text-sm font-medium transition shadow-sm whitespace-nowrap">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
            Nuevo
        </button>
    </div>


     @if (Model.Items.Count == 0)
    {
        <div class="border-b border-gray-50 dark:border-slate-700/50 p-4 transition-all group">
            <div class="flex justify-center items-center mb-1">
                <h3 class="text-gray-400 dark:text-gray-500 transition-colors">Sin registros</h3>
            </div>
        </div>
    }
    else
    {
        <div class="flex-1 overflow-y-auto custom-scrollbar min-h-0">
            @foreach (var item in Model.Items)
            {
                <div 
                    @@click="selectedId = @item.IdAddOn"
                    hx-get="@Url.Page("Index", "Form", new { id = item.IdAddOn })"
                    hx-target="#form-container"
                    :class="selectedId === @item.IdAddOn 
                        ? 'bg-blue-50 dark:bg-blue-900/20 border-l-4 border-blue-500' 
                        : 'hover:bg-gray-50 dark:hover:bg-slate-700/50 border-l-4 border-transparent border-b border-gray-50 dark:border-slate-700/50'"
                    class="p-4 cursor-pointer transition-all group">
                    
                    <div class="flex justify-between items-start mb-1">
                        <h3 class="font-bold text-gray-800 dark:text-gray-200 group-hover:text-blue-700 dark:group-hover:text-blue-400 transition-colors">
                            @item.Name
                        </h3>
                        <span class="text-xs font-mono font-bold bg-gray-100 dark:bg-slate-900 text-gray-600 dark:text-gray-400 px-1.5 py-0.5 rounded border border-gray-200 dark:border-slate-600">
                            $ @item.Price
                        </span>
                    </div>
                    
                    <div class="flex justify-between items-center text-xs text-gray-500 dark:text-gray-400">
                        <span class="@(item.IsActive ? "text-green-700 dark:text-green-400 bg-green-50 dark:bg-green-900/30 dark:border-green-900" : "text-gray-400 dark:text-gray-500 bg-gray-100 dark:bg-slate-700 dark:border-slate-600") px-2 py-0.5 rounded-full border border-transparent">
                            @(item.IsActive ? "Visible" : "No Visible")
                        </span>
                    </div>
                </div>
            }

        </div>
        
       <div class="p-2 bg-gray-50 dark:bg-slate-800 border-t border-gray-200 dark:border-slate-700 text-xs text-center text-gray-400 dark:text-gray-500 shrink-0 z-20">
            Mostrando @Model.Items.Count registros
        </div>
    }
     
</div>