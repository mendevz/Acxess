@using Microsoft.AspNetCore.Mvc.ModelBinding

@{
    // 1. Extraemos los mensajes del ViewData
    var successMsg = ViewData["SuccessMessage"] as string;
    var errorMsg = ViewData["ErrorMessage"] as string;
    
    // 2. Determinamos qué mostrar
    var hasSuccess = !string.IsNullOrEmpty(successMsg);
    var hasError = !string.IsNullOrEmpty(errorMsg);
    var hasValidationErrors = !ViewData.ModelState.IsValid;
}

@* -------------------------------------------------------------------------
   CASO 1: ÉXITO (Toast Verde con Auto-Dismiss)
   ------------------------------------------------------------------------- *@
@if (hasSuccess)
{
    <div x-data="{ show: true }"
         x-show="show"
         x-init="setTimeout(() => show = false, 5000)" 
         x-transition:enter="transition ease-out duration-300"
         x-transition:enter-start="opacity-0 translate-y-2"
         x-transition:enter-end="opacity-100 translate-y-0"
         x-transition:leave="transition ease-in duration-300"
         x-transition:leave-start="opacity-100 translate-y-0"
         x-transition:leave-end="opacity-0 translate-y-2"
         class="mb-4 rounded-lg border border-emerald-200 bg-emerald-50 dark:bg-emerald-900/20 dark:border-emerald-800 p-4 shadow-lg flex items-start gap-3">
        
        <div class="shrink-0 text-emerald-500">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
        </div>
        <div class="flex-1">
            <h3 class="text-sm font-bold text-emerald-800 dark:text-emerald-400">¡Operación exitosa!</h3>
            <div class="mt-1 text-sm text-emerald-700 dark:text-emerald-300">
                @successMsg
            </div>
        </div>
        <button type="button" @@click="show = false" class="text-emerald-500 hover:text-emerald-700 dark:hover:text-emerald-300 transition-colors">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
    </div>
}

@* -------------------------------------------------------------------------
   CASO 2: ERROR DE SISTEMA / LÓGICA (Toast Rojo - Sin Auto-Dismiss)
   ------------------------------------------------------------------------- *@
@if (hasError)
{
    <div x-data="{ show: true }"
         x-show="show"
         x-transition.opacity
         class="mb-4 rounded-lg border border-red-200 bg-red-50 dark:bg-red-900/20 dark:border-red-800 p-4 shadow-md flex items-start gap-3 animate-pulse-once">
        
        <div class="shrink-0 text-red-500">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
        </div>
        <div class="flex-1">
            <h3 class="text-sm font-bold text-red-800 dark:text-red-400">Error del sistema</h3>
            <div class="mt-1 text-sm text-red-700 dark:text-red-300">
                @errorMsg
            </div>
        </div>
        <button type="button" @@click="show = false" class="text-red-400 hover:text-red-600 dark:hover:text-red-200 transition-colors">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
    </div>
}

@* -------------------------------------------------------------------------
   CASO 3: ERRORES DE VALIDACIÓN (ModelState - Caja Naranja)
   ------------------------------------------------------------------------- *@
@if (hasValidationErrors)
{
    <div class="mb-4 rounded-lg border border-orange-200 bg-orange-50 dark:bg-orange-900/20 dark:border-orange-800 p-4 shadow-sm flex items-start gap-3 animate-shake">
        <div class="shrink-0 text-orange-500 mt-0.5">
            <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
            </svg>
        </div>
        <div class="flex-1">
            <h3 class="text-sm font-bold text-orange-800 dark:text-orange-400">Verifica los siguientes datos:</h3>
            
            <div class="mt-2 text-sm text-orange-700 dark:text-orange-300 validation-list-style">
                @* IMPORTANTE: Usamos "All" en lugar de "ModelOnly" para que liste 
                   aquí los errores específicos de los campos (ej: Nombre requerido),
                   especialmente útil si tus inputs en la UI compleja no tienen 
                   el <span> de error individual cerca.
                *@
                <div asp-validation-summary="All" class="text-orange-700 dark:text-orange-300"></div>
            </div>
        </div>
    </div>
}

@* ESTILOS INCRUSTADOS (SCOPED)
   Para asegurar que la animación funcione sin depender de tu CSS global 
*@
<style>
    /* Estilo para la lista de errores de ASP.NET */
    .validation-list-style ul {
        list-style-type: none;
        padding: 0;
        margin: 0;
    }
    .validation-list-style li {
        position: relative;
        padding-left: 1rem;
        margin-bottom: 0.25rem;
    }
    .validation-list-style li::before {
        content: "•"; /* Bullet personalizado */
        position: absolute;
        left: 0;
        color: currentColor;
        font-weight: bold;
    }

    /* Animación de vibración para errores */
    @@keyframes shake {
        0%, 100% { transform: translateX(0); }
        10%, 30%, 50%, 70%, 90% { transform: translateX(-2px); }
        20%, 40%, 60%, 80% { transform: translateX(2px); }
    }
    .animate-shake {
        animation: shake 0.4s cubic-bezier(.36,.07,.19,.97) both;
    }
</style>