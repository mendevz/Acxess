<div class="mt-auto bg-blue-50 dark:bg-blue-900/20 p-4 rounded-lg border border-blue-100 dark:border-blue-900/50">

    <div class="mb-2 flex flex-wrap items-center gap-2">
        <template x-if="mode === 'renew' && (selectedMember?.IsProrrogation)">
            <span class="px-2 py-0.5 rounded text-[10px] font-bold bg-orange-100 text-orange-700 border border-orange-200 dark:bg-orange-900/30 dark:text-orange-400 dark:border-orange-800">
                RENOVACIÓN 
            </span>
        </template>
        <template x-if="mode === 'renew' && (!selectedMember?.IsSubscriptionActive)">
            <span class="px-2 py-0.5 rounded text-[10px] font-bold bg-orange-100 text-orange-700 border border-orange-200 dark:bg-orange-900/30 dark:text-orange-400 dark:border-orange-800">
                RENOVACIÓN 
            </span>
        </template>
        <template x-if="mode === 'renew' && selectedMember?.IsSubscriptionActive && !selectedMember?.IsProrrogation">
            <span class="px-2 py-0.5 rounded text-[10px] font-bold bg-emerald-100 text-emerald-700 border border-emerald-200 dark:bg-emerald-900/30 dark:text-emerald-400 dark:border-emerald-800">
                PRONTO PAGO
            </span>
        </template>
    </div>

    <div class="flex justify-between items-end text-sm mb-1 gap-2">
        <div class="flex flex-col flex-shrink-0">
            <span class="text-xs text-blue-600 dark:text-blue-400">Inicia:</span>
            <strong class="text-base md:text-lg text-blue-900 dark:text-blue-200" x-text="formatDate(startDateDisplay)"></strong>
        </div>

        <div class="text-right flex flex-col">
            <span class="text-xs text-blue-600 dark:text-blue-400">Vence:</span>
            <strong class="text-lg md:text-xl text-blue-900 dark:text-blue-200 leading-tight" x-text="formatDate(calculatedEndDate)"></strong>
        </div>
    </div>

    <div x-show="mode === 'renew' && selectedMember?.IsSubscriptionActive" 
         class="text-[11px] text-blue-600/80 dark:text-blue-400 mt-2 italic border-t border-blue-200 dark:border-blue-800 pt-2 leading-tight">
        * Al estar vigente, los días del nuevo plan se sumarán a partir del <span x-text="formatDate(new Date(selectedMember?.LastExpirationDate))"></span>.
    </div>
</div>