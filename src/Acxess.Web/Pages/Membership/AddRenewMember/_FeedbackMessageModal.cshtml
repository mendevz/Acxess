@model Acxess.Web.Pages.Membership.AddRenewMember.IndexModel

@if (ViewData["ErrorMessage"] != null)
{
    <div class="fixed top-4 right-4 z-[100] bg-red-100 dark:bg-red-900/30 border-l-4 border-red-500 dark:border-red-800 text-red-700 dark:text-red-400 p-4 rounded shadow-lg animate-in slide-in-from-right-5"
         x-data="{ show: true }" x-show="show">
        <div class="flex justify-between items-start gap-4">
            <div>
                <p class="font-bold">Error</p>
                <p class="text-sm">@ViewData["ErrorMessage"]</p>
            </div>
            <button @@click="show = false" class="text-red-500 dark:text-red-400 hover:text-red-700 dark:hover:text-red-300 font-bold">&times;</button>
        </div>
    </div>
}

@if (ViewData["SuccessMessage"] != null && ViewData["TargetUrl"] != null)
{
    <div class="fixed inset-0 z-[100] flex items-center justify-center bg-black/80 backdrop-blur-sm p-4">
        <div class="bg-white dark:bg-slate-800 rounded-xl shadow-2xl w-full max-w-sm overflow-hidden animate-in fade-in zoom-in duration-300 border border-gray-100 dark:border-slate-700">
            <div class="flex flex-col items-center justify-center p-8 pb-6 space-y-4 text-center">

                <div class="w-16 h-16 bg-emerald-100 dark:bg-emerald-900/30 text-emerald-600 dark:text-emerald-400 rounded-full flex items-center justify-center mb-2 shadow-sm border border-emerald-200 dark:border-emerald-800/50">
                    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                </div>

                <div>
                    <h4 class="text-xl font-bold text-gray-800 dark:text-white">¡Registro Exitoso!</h4>
                    <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">@ViewData["SuccessMessage"]</p>
                </div>

                <div class="mt-6 w-full flex flex-col gap-3">
                    @if (ViewData["TargetUrl"] != null)
                    {
                        <a href="@ViewData["TargetUrl"]" class="w-full bg-blue-50 dark:bg-blue-900/20 text-blue-600 dark:text-blue-400 border border-blue-200 dark:border-blue-800/50 hover:bg-blue-100 dark:hover:bg-blue-900/40 font-semibold py-2.5 px-4 rounded-lg transition-colors flex justify-center items-center gap-2 shadow-sm">
                            <span>Ver Expediente del Socio</span>
                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
                        </a>
                    }
                    <button type="button"
                        @@click="window.location.href = window.location.pathname + '?mode=' + mode;"
                            class="w-full bg-gray-900 dark:bg-slate-700 hover:bg-gray-800 dark:hover:bg-slate-600 text-white font-semibold py-2.5 px-4 rounded-lg shadow transition-colors border border-transparent dark:border-slate-600">
                        Aceptar
                    </button>
                </div>
            </div>
        </div>
    </div>
}