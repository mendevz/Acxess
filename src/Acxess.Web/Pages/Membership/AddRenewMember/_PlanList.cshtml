@model IndexModel


@foreach (var plan in Model.PlanItems)
{

    <div 
        @@click='selectPlan(@Json.Serialize(plan))'
    
        :class="selectedPlan?.idSellingPlan === @plan.IdSellingPlan
           ? 'ring-2 ring-blue-500 bg-white dark:bg-slate-800 shadow-md'
           : 'bg-white dark:bg-slate-800 border-gray-200 dark:border-slate-700 hover:border-blue-300 dark:hover:border-blue-500'"
        class="cursor-pointer p-4 rounded-xl border transition-all relative group">

            <div class="flex justify-between items-start">
                <div>
                    <h3 class="font-bold text-gray-800 dark:text-white" >@plan.Name</h3>
                    @* <p class="text-xs text-gray-500 dark:text-gray-400 mt-1" x-text="plan.desc">@plan.</p> *@
                    <p class="text-xs text-gray-500 dark:text-gray-400 mt-2">
                        Acceso por 
                        <span class="font-bold" >@plan.DurationInValue</span> 
                        <span >@plan.DurationDescription</span>
                    </p>
                    
                    <span  class="mt-2 inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-purple-100 text-purple-800 dark:bg-purple-900/30 dark:text-purple-300">
                        <svg class="mr-1 h-3 w-3" fill="currentColor" viewBox="0 0 20 20"><path d="M13 6a3 3 0 11-6 0 3 3 0 016 0zM18 8a2 2 0 11-4 0 2 2 0 014 0zM14 15a4 4 0 00-8 0v3h8v-3zM6 8a2 2 0 11-4 0 2 2 0 014 0zM16 18v-3a5.972 5.972 0 00-.75-2.906A3.005 3.005 0 0119 15v3h-3zM4.75 12.094A5.973 5.973 0 004 15v3H1v-3a3 3 0 013.75-2.906z"></path></svg>
                        <span >@plan.TotalMembers Personas</span>
                    </span>
                    
                    <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">
                        <span >@plan.AccessTiers</span>
                    </p>
                </div>
                <span class="text-lg font-bold text-blue-600 dark:text-blue-400" >$@plan.Price</span>
            </div>
    
            <div x-show="selectedPlan?.idSellingPlan === @plan.IdSellingPlan" class="absolute top-1 right-1 text-blue-500" x-transition.scale>
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
            </div>
        </div>
}
