@model IndexModel

<div class="p-6 flex flex-col gap-6 overflow-y-auto custom-scrollbar flex-1">
    <div x-show="mode === 'renew'" x-transition:enter="transition ease-out duration-200" x-transition:enter-start="opacity-0 -translate-y-2" x-transition:enter-end="opacity-100 translate-y-0">
        <label class="block text-xs font-bold text-gray-500 dark:text-gray-400 uppercase mb-1">
            Buscar Socio 
        </label>
        <div class="relative group">
            <input
                type="text"
                id="search-member-input"
                name="SearchMember"
                value="@Model.SearchMember"
                placeholder="Nombre del socio o ID"
                hx-get="@Url.Page("Index", pageHandler: "Member")"
                hx-trigger="keyup changed delay:500ms"
                hx-target="#members-list"
                hx-swap="innerHTML"
                @@focus="$el.select()"
                class="w-full p-3 bg-gray-50 dark:bg-slate-900 border border-gray-300 dark:border-slate-600 rounded-lg shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 dark:focus:border-blue-500 outline-none text-sm text-gray-900 dark:text-white placeholder-gray-400 dark:placeholder-gray-500 transition-all">
            <div class="absolute right-3 top-3.5 text-gray-400 group-focus-within:text-blue-500">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
            </div>
        </div>
        <div id="members-list"></div>
    </div>

    <div x-show="mode !== 'visit'" class="flex items-center gap-2 ">
        <div class="h-px bg-gray-200 dark:bg-slate-600 flex-1"></div>
        <span  class="text-gray-400 dark:text-gray-500 text-xs font-semibold">DATOS DEL TITULAR</span>
        <div class="h-px bg-gray-200 dark:bg-slate-600 flex-1"></div>
    </div>
    
    <div x-show="mode !== 'visit'" 
         class="flex justify-center my-1" 
         @@photo-captured.window="customer.PhotoBase64 = $event.detail">
        
        <input type="hidden" name="OrderRequest.MemberData.PhotoBase64" :value="customer.PhotoBase64">

        <div @@click="$dispatch('open-camera-modal')" 
             title="Clic para tomar o cambiar fotografía"
             class="relative w-24 h-24 rounded-full bg-gray-200 dark:bg-slate-700 border-4 border-white dark:border-slate-800 shadow-md flex items-center justify-center cursor-pointer overflow-hidden group hover:ring-2 hover:ring-blue-500 transition-all">
            
            <template x-if="customer.PhotoBase64">
                <img :src="customer.PhotoBase64" class="w-full h-full object-cover">
            </template>
            
            <template x-if="!customer.PhotoBase64 && customer.PhotoUrl">
                <img :src="customer.PhotoUrl" class="w-full h-full object-cover">
            </template>
            
            <template x-if="!customer.PhotoBase64 && !customer.PhotoUrl">
                <svg class="w-10 h-10 text-gray-400 dark:text-gray-500 group-hover:text-blue-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
            </template>

            <div class="absolute inset-0 bg-black/50 flex flex-col items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">
                <svg class="w-6 h-6 text-white mb-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"></path></svg>
                <span class="text-[8px] text-white font-bold uppercase tracking-wider">Cambiar</span>
            </div>
        </div>
    </div>
    
    <div class="space-y-4">
        <input type="hidden" name="OrderRequest.MemberData.Id" :value="mode === 'new' ? 0 : (customer.Id || 0)">
        
        <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300">Nombre</label>
            <input 
                id="first-name-input"
                type="text"
               x-model="customer.FirstName"
               name="OrderRequest.MemberData.FirstName"
               placeholder="Nombre del socio"
               :readonly="mode === 'renew'"
                class="form-input-acxess"
                @@focus="$el.select()">
        </div>
        <div x-show="mode !== 'visit'">
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300">Apellidos</label>
            <input type="text"
                   x-model="customer.LastName"
                   placeholder="Apellidos del socio"
                   name="OrderRequest.MemberData.LastName"
                   :readonly="mode === 'renew' "
                   class="form-input-acxess"
                   @@focus="$el.select()">
        </div>
        <div x-show="mode !== 'visit'">
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300">Teléfono <span class="text-xs">(Opcional)</span></label>
            <input type="tel"
                   x-model="customer.Phone"
                   placeholder="Telefono o celular"
                   name="OrderRequest.MemberData.Phone"
                   :readonly="mode === 'renew' "
                   class="form-input-acxess"
                   @@focus="$el.select()">
        </div>
    </div>

    <div x-show="mode === 'new'" class="mt-2 py-3 px-4 bg-gray-50 dark:bg-slate-800/40 border border-gray-200 dark:border-slate-700 rounded-lg transition-colors"
         :class="omitInscription ? 'bg-orange-50/50 dark:bg-orange-900/10 border-orange-200 dark:border-orange-800/50' : ''">
        
        <label class="flex items-start gap-3 cursor-pointer group">
            <div class="relative flex items-center justify-center shrink-0 mt-0.5">
                <input type="checkbox" 
                       x-model="omitInscription" 
                       @@change="toggleInscription()" 
                       class="peer appearance-none w-4 h-4 border border-gray-300 dark:border-slate-500 rounded-sm bg-white dark:bg-slate-900 checked:bg-orange-500 checked:border-orange-500 focus:outline-none focus:ring-2 focus:ring-orange-500/50 focus:ring-offset-1 dark:focus:ring-offset-slate-900 transition-all cursor-pointer">
                <svg class="absolute w-3 h-3 text-white opacity-0 peer-checked:opacity-100 pointer-events-none transition-opacity" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path>
                </svg>
            </div>
            
            <div class="flex flex-col">
                <span class="text-sm font-medium transition-colors" 
                      :class="omitInscription ? 'text-orange-700 dark:text-orange-400' : 'text-gray-700 dark:text-gray-300 group-hover:text-gray-900 dark:group-hover:text-white'">
                    Es socio existente (Omitir inscripción)
                </span>
                <span class="text-[10px] transition-colors mt-0.5"
                      :class="omitInscription ? 'text-orange-600/80 dark:text-orange-400/80' : 'text-gray-500 dark:text-gray-400'">
                    <span x-show="!omitInscription">Se cobrará la cuota de nuevo ingreso por defecto.</span>
                    <span x-show="omitInscription" x-cloak>No se cobrará la cuota de inscripción a este socio.</span>
                </span>
            </div>
        </label>
    </div>
</div>