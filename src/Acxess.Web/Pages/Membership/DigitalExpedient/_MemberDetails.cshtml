@model IndexModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    var m = Model.SelectedMember;
    if(m == null) return;
}
<div 
    hx-trigger="memberUpdated from:body" 
    hx-get="@Url.Page("Index", "MemberDetail", new { id = m.IdMember })" 
    hx-target="#member-detail-container"  hx-swap="innerHTML"
    class="@(m.IsDeleted ? "opacity-75 grayscale" : "") bg-white dark:bg-slate-800 p-4 sm:p-8 border-b border-gray-200 dark:border-slate-700 shadow-sm">
    
    <button @@click="selectedMemberId = null" class="md:hidden flex items-center gap-2 text-gray-500 hover:text-blue-600 dark:text-gray-400 dark:hover:text-blue-400 font-bold mb-4 bg-gray-100 hover:bg-blue-50 dark:bg-slate-700 dark:hover:bg-slate-600 px-3 py-1.5 rounded-lg w-fit transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
        Volver a la lista
    </button>

    <div class="flex flex-col xl:flex-row justify-between items-start gap-5 xl:gap-0">
        
        <div class="flex gap-4 sm:gap-5 w-full">
            <div x-data="{ showLightbox: false, photoBase64: '' }" 
                 @@photo-captured.window="photoBase64 = $event.detail; $nextTick(() => document.getElementById('update-photo-btn').click())"
                 class="relative shrink-0">
                
                <div @@click="@(string.IsNullOrEmpty(m.PhotoUrl) ? "" : "showLightbox = true")" 
                     class="w-16 h-16 sm:w-20 sm:h-20 rounded-xl bg-slate-200 dark:bg-slate-800 text-slate-500 flex items-center justify-center text-xl sm:text-2xl font-bold shadow-lg border-2 border-slate-100 dark:border-slate-700 overflow-hidden group transition-all @(!string.IsNullOrEmpty(m.PhotoUrl) ? "cursor-pointer" : "")">
                    
                    @if (!string.IsNullOrEmpty(m.PhotoUrl))
                    {
                        <img src="@m.PhotoUrl" alt="Foto de @m.FullName" class="w-full h-full object-cover group-hover:scale-105 transition-transform" />
                    }
                    else
                    {
                        <span>@m.Initials</span>
                    }
                </div>

                <button @@click.stop="$dispatch('open-camera-modal')" 
                        title="Cambiar fotografía"
                        class="absolute -bottom-2 -right-2 bg-blue-600 hover:bg-blue-500 text-white p-1.5 sm:p-2 rounded-full shadow-md border-2 border-white dark:border-slate-800 transition-colors z-10">
                    <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"></path></svg>
                </button>

                <form id="photo-form" hx-post="@Url.Page("Index", "UpdatePhoto")" hx-swap="none" class="hidden">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@m.IdMember" />
                    <input type="hidden" name="photoBase64" :value="photoBase64" />
                    <button type="submit" id="update-photo-btn"></button>
                </form>

                @if (!string.IsNullOrEmpty(m.PhotoUrl))
                {
                    <div x-show="showLightbox" style="display: none;" 
                         class="fixed inset-0 z-[99999] flex items-center justify-center bg-black/90 backdrop-blur-sm p-4 animate-in fade-in zoom-in duration-200"
                         @@click="showLightbox = false"
                         @@keydown.escape.window="showLightbox = false">
                        
                        <button type="button" class="absolute top-4 right-4 sm:top-6 sm:right-6 text-white/50 hover:text-white transition-colors bg-black/50 rounded-full p-2">
                            <svg class="w-6 h-6 sm:w-8 sm:h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                        </button>

                        <img src="@m.PhotoUrl" alt="Foto en grande de @m.FullName" class="max-w-full max-h-[90vh] rounded-lg shadow-2xl object-contain border border-slate-700" @@click.stop />
                    </div>
                }
            </div>

            <div class="overflow-hidden">
                <h2 class="text-xl sm:text-2xl font-bold text-gray-900 dark:text-white truncate">@m.FullName</h2>
                @if (!string.IsNullOrWhiteSpace(m.Email))
                {
                    <span class="font-mono text-gray-400 text-xs sm:text-sm truncate block">@m.Email</span>
                }
                <div class="flex flex-wrap items-center gap-2 sm:gap-3 mt-1 text-xs sm:text-md text-gray-500 dark:text-gray-400">
                    <span class="font-mono text-gray-400">ID:<span class="font-bold">@m.IdMember</span></span>
                    @if (!string.IsNullOrWhiteSpace(m.Phone))
                    {
                        <span class="hidden sm:inline">•</span>
                        <span class="flex items-center justify-center gap-1">
                            <svg class="w-3 h-3 sm:w-4 sm:h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                            <span >@m.Phone</span>
                        </span>
                    }
                </div>

                <div class="mt-3 flex gap-2">
                    <span class="px-2 py-0.5 rounded text-[10px] sm:text-xs font-bold uppercase tracking-wider border 
                                        @(m.StatusColor switch
                                        {
                                            "green" => "bg-green-100 text-green-700 border-green-200 dark:bg-green-900/30 dark:text-green-400 dark:border-green-800",
                                            "red" => "bg-red-100 text-red-700 border-red-200 dark:bg-red-900/30 dark:text-red-400 dark:border-red-800",
                                            "yellow" => "bg-orange-100 text-orange-700 border-orange-200 dark:bg-orange-900/30 dark:text-orange-400 dark:border-orange-800",
                                            _ => "bg-gray-100 text-gray-600 border-gray-200 dark:bg-slate-800 dark:text-slate-400 dark:border-slate-700"
                                        })">
                        @m.StatusLabel
                    </span>
                </div>
            </div>
        </div>

        <div class="flex flex-col sm:flex-row xl:flex-col gap-2 w-full xl:w-auto mt-2 xl:mt-0">
            @if(m.IsDeleted)
            {
                <div class="p-3 bg-red-50 border border-red-100 text-red-600 text-sm rounded-lg text-center font-medium animate-in fade-in w-full">
                    El socio fue dado de baja.
                    <form hx-post="@Url.Page("Index", "RestoreMember", new { id = m.IdMember })"
                          hx-target="#modal-container"
                          hx-swap="innerHTML"
                          class="inline-block ml-1">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="underline cursor-pointer font-bold hover:text-red-800">
                            Restaurar usuario
                        </button>
                    </form>
                </div>
            }
            else
            {
                <a href="@Url.Page("/Membership/AddRenewMember/Index", new { MemberId = m.IdMember })"
                   class="bg-blue-600 hover:bg-blue-700 disabled:bg-gray-400 text-white px-4 py-2 rounded-lg text-sm font-bold shadow-sm transition flex items-center justify-center gap-2 w-full sm:w-auto xl:w-40">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
                    Renovar (F2)
                </a>

                <button 
                    hx-get="@Url.Page("Index", "EditMember", new { id = m.IdMember })"
                    hx-target="#modal-container"
                    hx-swap="innerHTML"
                    class="bg-white dark:bg-slate-700 border border-gray-300 dark:border-slate-600 hover:bg-gray-50 dark:hover:bg-slate-600 text-gray-700 dark:text-gray-200 px-4 py-2 rounded-lg text-sm font-medium transition flex items-center justify-center gap-2 w-full sm:w-auto xl:w-40">
                    <svg class="w-4 h-4 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path>
                    </svg>
                    Editar 
                </button>
                
                @if (!m.HasActiveSubscription)
                {
                    <button hx-get="@Url.Page("Index", "DeleteMemberModal", new { id = m.IdMember })"
                            hx-target="#modal-container"
                            hx-swap="innerHTML"
                            class="mt-2 text-xs text-red-400 hover:text-red-600 hover:underline flex items-center justify-center gap-1 transition-colors w-full xl:w-40">
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                        Eliminar Socio
                    </button>
                }
                else
                {
                    <button 
                        hx-get="@Url.Page("Index", "AssignCoupon", new { id = m.IdMember })"
                        hx-target="#modal-container"
                        hx-swap="innerHTML"
                        class="bg-transparent hover:bg-gray-100 dark:hover:bg-slate-700 text-gray-500 dark:text-gray-400 px-4 py-1.5 rounded-lg text-xs font-medium transition flex items-center justify-center gap-2 w-full xl:w-40">
                        <svg class="w-4 h-4 text-pink-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path></svg>
                        Asignar Cupón
                    </button>
                }
            }
        </div>
    </div>
</div>

<div class="p-4 sm:p-8 space-y-4 sm:space-y-6">

    <div class="bg-white dark:bg-slate-800 rounded-xl shadow-sm border border-gray-200 dark:border-slate-700 overflow-hidden">
        <div class="bg-gray-50 dark:bg-slate-700/50 px-4 sm:px-6 py-3 border-b border-gray-200 dark:border-slate-700 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-2 sm:gap-0">
            <h3 class="font-bold text-gray-700 dark:text-gray-300 text-xs sm:text-sm uppercase tracking-wide">
                @if(m.HasActiveSubscription) { <span>Membresía Activa</span> }
                else if(m.IsSubscriptionCancelled) { <span class="text-red-500 flex items-center gap-1"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg> Cancelada</span> }
                else if(m.IsInGracePeriod) { <span class="text-orange-500">⚠ Vencido</span> }
                else { <span>Membresía Vencida</span> }
            </h3>
            @if(m.HasActiveSubscription)
            {
                <div class="flex items-center justify-between w-full sm:w-auto gap-3">
                    <span class="text-green-600 dark:text-green-400 text-[10px] sm:text-xs font-bold flex items-center gap-1">
                        <span class="w-2 h-2 bg-green-500 rounded-full animate-pulse"></span> Al corriente
                    </span>
            
                    <button hx-get="@Url.Page("Index", "CancelSubscriptionModal", new { id = m.IdMember })"
                            hx-target="#modal-container"
                            hx-swap="innerHTML"
                            class="text-[10px] font-medium px-2 py-1 rounded border shadow-sm transition-all duration-200
                                   bg-white border-gray-200 text-gray-500 hover:text-red-600 hover:border-red-300 hover:bg-red-50
                                   dark:bg-gray-800 dark:border-gray-700 dark:text-gray-400 dark:hover:text-red-400 dark:hover:border-red-900 dark:hover:bg-red-950/30"
                            title="Cancelar Suscripción">
                        Cancelar
                    </button>
                </div>
            }
        </div>

        <div class="p-4 sm:p-6 grid grid-cols-1 sm:grid-cols-2 gap-4 sm:gap-6">
            <div>
                <p class="text-[10px] sm:text-xs text-gray-500 dark:text-gray-400 uppercase">Plan Contratado</p>
                <p class="text-lg sm:text-xl font-bold text-slate-800 dark:text-white">@m.PlanName</p>
                
                @if(m.ActiveAddOns.Any())
                {
                    <div class="mt-2 sm:mt-3 flex flex-wrap gap-2">
                        @foreach(var addon in m.ActiveAddOns)
                        {
                            <span class="inline-flex items-center px-2 py-1 rounded bg-blue-50 text-blue-700 text-[10px] sm:text-xs font-medium border border-blue-100 
                                        dark:bg-blue-900/30 dark:text-blue-400 dark:border-blue-800">
                                + @addon
                            </span>
                        }
                    </div>
                }
            </div>
            <div class="text-left sm:text-right pt-3 sm:pt-0 border-t sm:border-0 border-gray-100 dark:border-slate-700">
                <p class="text-[10px] sm:text-xs text-gray-500 uppercase">Vence el</p>
                @if(m.AbsoluteExpirationDate.HasValue)
                {
                    <p class="text-xl sm:text-2xl font-mono font-bold @(m.ColorSubscription)">
                        @m.AbsoluteExpirationDate.Value.ToString("dd MMM yyyy")
                    </p>
                            
                    <p class="text-[10px] sm:text-xs mt-1 font-semibold @(m.ColorSubscription)">
                        @m.RenewalMessage
                    </p>
                            
                    @if(m.HasActiveSubscription) {
                        <p class="text-[10px] sm:text-xs text-blue-500 mt-1">Quedan @m.RemainingDays días</p>
                    }
                }
                else
                {
                    <p class="text-gray-400 text-lg sm:text-xl">--</p>
                }
            </div>
        </div>
        @if(m.AbsoluteExpirationDate.HasValue)
        {
            <div class="w-full bg-gray-200 dark:bg-slate-700 h-1.5 relative" title="Progreso de la suscripción">
                <div class="h-1.5 transition-all duration-1000 ease-out @(m.ColorSubscription.Replace("text-", "bg-"))"
                     style="width: @m.ProgressPercentage%">
                </div>
            </div>
        }
    </div>

    <div class="grid grid-cols-1 xl:grid-cols-2 gap-4 sm:gap-6">
        
        <div class="bg-white dark:bg-slate-800 p-4 sm:p-5 rounded-xl border border-gray-200 dark:border-slate-700 shadow-sm flex flex-col justify-center">
            <div class="flex items-center gap-2 mb-3 sm:mb-4 border-b border-gray-100 dark:border-slate-700 pb-2">
                <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                <h4 class="text-[10px] sm:text-xs font-bold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Perfil del Socio</h4>
            </div>

            <div class="space-y-2">
                <div class="flex justify-between items-center group">
                    <span class="text-xs sm:text-sm text-gray-600 dark:text-gray-300 flex items-center gap-2">
                        <span class="p-1 sm:p-1.5 rounded-md bg-gray-50 dark:bg-slate-700 text-gray-400">
                            <svg class="w-3 h-3 sm:w-4 sm:h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        </span>
                        Hábito de Pago
                    </span>

                    <span class="inline-flex items-center gap-1.5 px-1.5 py-1 rounded-full text-[10px] sm:text-xs font-bold border
                             @(m.PaymentBehaviorColor == "green" ? "bg-green-50 text-green-700 border-green-200 dark:bg-green-900/20 dark:text-green-400 dark:border-green-800" :
                             m.PaymentBehaviorColor == "red" ? "bg-red-50 text-red-700 border-red-200 dark:bg-red-900/20 dark:text-red-400 dark:border-red-800" :
                             "bg-yellow-50 text-yellow-700 border-yellow-200 dark:bg-yellow-900/20 dark:text-yellow-400 dark:border-yellow-800")">
                        <span class="w-1.5 h-1.5 rounded-full bg-current"></span>
                        @m.PaymentBehaviorLabel
                    </span>
                </div>
                
                <div class="flex justify-between items-center opacity-70" title="Próximamente">
                    <span class="text-xs sm:text-sm text-gray-600 dark:text-gray-300 flex items-center gap-2">
                         <span class="p-1 sm:p-1.5 rounded-md bg-gray-50 dark:bg-slate-700 text-gray-400">
                            <svg class="w-3 h-3 sm:w-4 sm:h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                        </span>
                        Frecuencia
                    </span>
                    <span class="text-[10px] sm:text-xs text-gray-400 font-medium italic">@m.LoyaltyLabel</span>
                </div>
            </div>
        </div>

        <div class="bg-white dark:bg-slate-800 p-4 sm:p-5 rounded-lg border border-gray-200 dark:border-slate-700 shadow-sm">
            <h4 class="text-xs sm:text-sm font-bold text-gray-800 dark:text-white mb-2">Estadísticas Rápidas</h4>
            <ul class="text-xs sm:text-sm space-y-2 sm:space-y-3">
                <li class="flex justify-between border-b border-gray-100 dark:border-slate-700 pb-1">
                    <span class="text-gray-500 dark:text-gray-400">Socio desde:</span>
                    <span class="font-medium text-gray-700 dark:text-gray-200">@m.MemberSinceLabel</span>
                </li>
                <li class="flex justify-between border-b border-gray-100 dark:border-slate-700 pb-1">
                    <span class="text-gray-500 dark:text-gray-400">Total gastado:</span>
                    <span class="font-medium text-green-600 dark:text-green-400">@m.TotalSpentLabel</span>
                </li>
            </ul>
        </div>
    </div>

</div>

<div hx-get="@Url.Page("Index", "MemberHistory", new { id = m.IdMember})"
     hx-trigger="load"
     hx-target="#member-history-container"
     hx-swap="innerHTML"
     class="hidden">
</div>