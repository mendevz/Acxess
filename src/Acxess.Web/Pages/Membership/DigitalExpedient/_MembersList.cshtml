@using Acxess.Shared.Constants
@model IndexModel
@{
    var isAppend = Model.CurrentPage > 1;
    var members = Model.MembersResponse?.Members.ToList() ?? [];
    const int pageSize = PaginationValues.PageSize;
}

@if (isAppend)
{
    @foreach (var member in members)
    {
        <div @@click="selectedMemberId = @member.IdMember"
             :class="selectedMemberId === @member.IdMember ? 'bg-blue-50 dark:bg-blue-900/20 border-l-4 border-blue-600 dark:border-blue-500' : 'hover:bg-gray-50 dark:hover:bg-slate-700/50  border-b border-gray-50 dark:border-slate-700/50'"
             class="p-4 cursor-pointer transition-all flex items-center gap-3 group"
             hx-get="@Url.Page("Index", "MemberDetail", new { id = member.IdMember })"
             hx-target="#member-detail-container"
             hx-swap="innerHTML">
            
            <div class="relative">
                <div class="w-10 h-10 rounded-full bg-slate-200 dark:bg-slate-700 flex items-center justify-center text-slate-500 dark:text-slate-300 font-bold text-sm border border-slate-300 dark:border-slate-600 shrink-0">
                    @if (!string.IsNullOrEmpty(member.PhotoUrl))
                    {
                        <img src="@member.PhotoUrl" alt="Foto de @member.FullName" class="w-full h-full object-cover rounded-full aspect-square">
                    }
                    else
                    {
                        <span>@member.Initials</span>
                    }
                </div>
                <div class="@(member.IsDeleted ? "bg-gray-400 dark:bg-gray-500" : (member.Active ? "bg-green-500" : "bg-orange-500")) absolute bottom-0 right-0 w-3 h-3 rounded-full border-2 border-white dark:border-slate-800"></div>
            </div>

            <div class="overflow-hidden">
                <p class="font-bold text-sm text-gray-800 dark:text-gray-200 truncate group-hover:text-blue-700 dark:group-hover:text-blue-400 transition-colors">
                    @member.FullName
                </p>
                <p class="text-xs text-gray-500 dark:text-gray-400 truncate">
                    @if (string.IsNullOrWhiteSpace(member.Phone)){
                        <span>ID: @member.IdMember</span> 
                    }else{
                        <span> ID: @member.IdMember • @member.Phone </span>   
                    } 
                </p>
            </div>
        </div>
    }

    @if (members.Count == pageSize)
    {
        <div hx-get="@Url.Page("Index", "Members", new { CurrentPage = Model.CurrentPage + 1 })"
             hx-trigger="intersect once"
             hx-swap="outerHTML"
             hx-include="#statusFilterHidden, [name='SearchTerm']"
             class="w-full h-10 flex-shrink-0 flex items-center justify-center text-gray-300 dark:text-slate-600">
         
            <svg class="animate-spin h-5 w-5" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
        </div>
    }
    
    <div id="members-counter" hx-swap-oob="true" class="p-2 bg-gray-50 dark:bg-slate-800 border-t border-gray-200 dark:border-slate-700 text-xs text-center text-gray-400 dark:text-gray-500 shrink-0 z-20">
        Mostrando @(((Model.CurrentPage - 1) * pageSize) + members.Count) de @((Model.MembersResponse?.TotalMembers ?? 0) - (Model.MembersResponse?.DeletedCount ?? 0))
    </div>
}
else
{
    <div class="flex flex-col flex-1 overflow-hidden opacity-0 transition-opacity duration-300 ease-out" 
         x-data
         x-init="setTimeout(() => $el.classList.remove('opacity-0'), 10)"
     x-transition:enter="transition ease-out duration-300"
     x-transition:enter-start="opacity-0"
     x-transition:enter-end="opacity-100">
    
    
        <div class="flex-1 overflow-y-auto custom-scrollbar">
            @if (Model.MembersResponse is not null)
            {
                foreach (var member in Model.MembersResponse.Members)
                {
                    <div 
                        @@click="selectedMemberId = @member.IdMember"
                        :class="selectedMemberId === @member.IdMember ? 'bg-blue-50 dark:bg-blue-900/20 border-l-4 border-blue-600 dark:border-blue-500' : 'hover:bg-gray-50 dark:hover:bg-slate-700/50  border-b border-gray-50 dark:border-slate-700/50'"
                        class="p-4 cursor-pointer transition-all flex items-center gap-3 group"
                        hx-get="@Url.Page("Index", "MemberDetail", new { id = member.IdMember })"
                        hx-target="#member-detail-container"
                        hx-swap="innerHTML"
                        cursor-pointer>

                        <div class="relative">
                            <div class="w-10 h-10 rounded-full bg-slate-200 dark:bg-slate-700 flex items-center justify-center text-slate-500 dark:text-slate-300 font-bold text-sm border border-slate-300 dark:border-slate-600 shrink-0">
                                @if (!string.IsNullOrEmpty(member.PhotoUrl))
                                {
                                    <img src="@member.PhotoUrl" alt="Foto de @member.FullName" class="w-full h-full object-cover rounded-full aspect-square">
                                }
                                else
                                {
                                    <span>@member.Initials</span>
                                }
                            </div>
                            <div class="@(member.IsDeleted ? "bg-gray-400 dark:bg-gray-500" : (member.Active ? "bg-green-500" : "bg-orange-500")) absolute bottom-0 right-0 w-3 h-3 rounded-full border-2 border-white dark:border-slate-800"></div>
                        </div>

                        <div class="overflow-hidden">
                            <p class="font-bold text-sm text-gray-800 dark:text-gray-200 truncate group-hover:text-blue-700 dark:group-hover:text-blue-400 transition-colors">
                                @member.FullName
                            </p>
                            <p class="text-xs text-gray-500 dark:text-gray-400 truncate">
                                @if (string.IsNullOrWhiteSpace(member.Phone)){
                                    <span>ID: @member.IdMember</span> 
                                }else{
                                    <span> ID: @member.IdMember • @member.Phone </span>   
                                } 
                            </p>
                        </div>
                    </div>
                }
                
                @if (members.Count == pageSize)
                {
                    <div hx-get="@Url.Page("Index", "Members", new { CurrentPage = Model.CurrentPage + 1 })"
                         hx-trigger="intersect once"
                         hx-swap="outerHTML"
                         hx-include="#statusFilterHidden, [name='SearchTerm']"
                         class="w-full h-10 flex-shrink-0 flex items-center justify-center text-gray-300 dark:text-slate-600">
         
                        <svg class="animate-spin h-5 w-5" fill="none" viewBox="0 0 24 24">
                            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                        </svg>
                    </div>
                }
            }
        </div>
        <div id="members-counter" class="p-2 bg-gray-50 dark:bg-slate-800 border-t border-gray-200 dark:border-slate-700 text-xs text-center text-gray-400 dark:text-gray-500 shrink-0 z-20">
            Mostrando @(Model.MembersResponse?.CountMembers ?? 0) de @((Model.MembersResponse?.TotalMembers ?? 0) - (Model.MembersResponse?.DeletedCount ?? 0))
        </div>
    </div>
}


