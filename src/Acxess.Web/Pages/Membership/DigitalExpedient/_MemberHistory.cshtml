@using System.Globalization
@model Acxess.Membership.Application.Features.Members.Queries.GetMemberHistory.MemberHistoryDto

<div class="p-3 sm:p-4 border-b border-gray-100 dark:border-slate-700 bg-gray-50 dark:bg-slate-800/50 sticky top-0 z-20 backdrop-blur-sm shrink-0">
    <h3 class="text-[10px] sm:text-xs font-bold text-gray-700 dark:text-gray-400 uppercase tracking-wider">Historial de Actividad</h3>
</div>

<div class="flex-1 overflow-y-auto p-4 sm:p-5 custom-scrollbar min-h-0">
    
    @if (!Model.Items.Any())
    {
        <div class="flex flex-col items-center justify-center h-32 sm:h-40 text-gray-400 text-xs sm:text-sm">
            <span>Sin actividad reciente</span>
        </div>
    }
    else
    {
        <div class="relative">
            <div class="absolute left-[17px] sm:left-[19px] top-2 bottom-4 w-0.5 bg-gray-200 dark:bg-slate-700 z-0"></div>

            @foreach (var item in Model.Items)
            {
                var isPayment = item.Type == "Payment";
                var iconBg = isPayment ? "bg-green-100 dark:bg-green-900/30 border-green-200 dark:border-green-800" : "bg-gray-100 dark:bg-slate-700 border-gray-200 dark:border-slate-600";
                var iconColor = isPayment ? "text-green-600 dark:text-green-400" : "text-gray-500 dark:text-gray-400";
                
                <div class="pl-10 sm:pl-12 pb-5 sm:pb-8 relative group">
                    <div class="absolute left-0 top-0 p-1 sm:p-1.5 rounded-full border z-10 @iconBg">
                        @if (isPayment)
                        {
                            <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4 @iconColor" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        }
                        else
                        {
                            <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4 @iconColor" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        }
                    </div>

                    <div class="flex justify-between items-start mb-1">
                        <span class="font-bold text-xs sm:text-sm text-gray-800 dark:text-gray-200">@item.Title</span>
                        <span class="text-[10px] sm:text-xs font-mono text-gray-400">@item.Date.ToString("dd MMM", new CultureInfo("es-ES"))</span>
                    </div>

                    @switch (item.Type)
                    {
                        case "Expiration":
                            <p class="text-[10px] sm:text-xs text-gray-500 dark:text-gray-400 mb-1.5">@item.Date.ToString("hh:mm tt")</p>
                            <p class="text-[10px] sm:text-xs text-red-500 dark:text-red-400 font-medium mb-1.5">Sistema desactivó acceso.</p>
                            break;
                        case "SubscriptionStart":
                            <p class="text-[10px] sm:text-xs text-gray-500 dark:text-gray-400 mb-1.5">@item.Date.ToString("hh:mm tt")</p>
                            <p class="text-[10px] sm:text-xs text-green-500 dark:text-green-400 font-medium mb-1.5">Sistema habilitó acceso.</p>
                            break;
                        default:
                            <p class="text-[10px] sm:text-xs text-gray-500 dark:text-gray-400 mb-1.5">@item.Date.ToString("hh:mm tt")</p>
                            break;
                    }

                    @if (item.Details.Any())
                    {
                        <div class="bg-gray-50 dark:bg-slate-700/30 p-2 sm:p-2.5 rounded border border-gray-100 dark:border-slate-600 text-[10px] sm:text-xs space-y-1">
                            @foreach (var detail in item.Details)
                            {
                                <div class="flex justify-between text-gray-600 dark:text-gray-300">
                                    <span>@detail</span> 
                                </div>
                            }
                            
                            @if (item.Amount.HasValue)
                            {
                                <div class="flex justify-between font-bold mt-1 pt-1 border-t border-gray-200 dark:border-slate-600 text-gray-800 dark:text-white">
                                    <span>Total</span> 
                                    <span>@item.Amount.Value.ToString("C", new CultureInfo("es-MX"))</span>
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    }
</div>

<div class="p-2 sm:p-3 border-t border-gray-200 dark:border-slate-700 text-center bg-white dark:bg-slate-800 shrink-0 sticky bottom-0 z-20">
    <button 
        hx-get="@Url.Page("Index", "FullHistory", new { id = Model.MemberId})" 
        hx-target="#modal-container" 
        hx-swap="innerHTML"
        class="w-full text-[10px] sm:text-xs font-bold text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300 transition-colors py-2 bg-gray-50/50 dark:bg-slate-700/30 rounded-lg">
        Ver historial completo
    </button>
</div>