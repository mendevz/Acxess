<div x-data="imageCaptureApp()" 
     @@open-camera-modal.window="openCamera()"
     x-show="isCameraOpen" 
     style="display: none;" 
     class="fixed inset-0 z-[9999] flex items-center justify-center bg-black/80 backdrop-blur-sm p-4">

    <div class="bg-white dark:bg-slate-900 rounded-2xl overflow-hidden shadow-2xl w-full max-w-md flex flex-col"
         @@click.away="closeCamera()">
        
        <div class="px-4 py-3 border-b border-gray-100 dark:border-slate-800 flex justify-between items-center bg-gray-50 dark:bg-slate-800/50">
            <h3 class="font-bold text-gray-800 dark:text-gray-200">Capturar Fotografía</h3>
            <button type="button" @@click="closeCamera()" class="text-gray-400 hover:text-red-500 transition-colors">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>
        </div>

        <div class="relative bg-black aspect-square md:aspect-[4/3] w-full flex items-center justify-center overflow-hidden">
            <video x-ref="videoElement" autoplay playsinline class="w-full h-full object-cover"></video>
            
            <button type="button" 
                    x-show="hasMultipleCameras" 
                    x-cloak
                    @@click="switchCamera()" 
                    class="absolute top-4 right-4 bg-black/60 hover:bg-black/80 text-white p-3 rounded-full backdrop-blur transition-all z-50 shadow-lg">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
            </button>
        </div>

        <div class="p-4 flex flex-col gap-3">
            <button type="button" @@click="takePhoto()" class="w-full bg-blue-600 hover:bg-blue-500 text-white font-bold py-3 rounded-lg shadow flex justify-center items-center gap-2 transition-all">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                Tomar Fotografía
            </button>

            <div class="relative flex items-center">
                <div class="flex-grow border-t border-gray-200 dark:border-slate-700"></div>
                <span class="flex-shrink-0 mx-4 text-gray-400 text-xs">O también puedes</span>
                <div class="flex-grow border-t border-gray-200 dark:border-slate-700"></div>
            </div>

            <label class="w-full bg-gray-100 dark:bg-slate-800 hover:bg-gray-200 dark:hover:bg-slate-700 text-gray-700 dark:text-gray-300 font-semibold py-2.5 rounded-lg border border-gray-200 dark:border-slate-700 flex justify-center items-center gap-2 cursor-pointer transition-all">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"></path></svg>
                Subir desde el dispositivo
                <input type="file" accept="image/*" class="hidden" @@change="handleFileUpload(event)">
            </label>
        </div>
    </div>
</div>